# ─────────────────────────────────────────────────────────────────────────────
# AI-HR Manager — Root Environment Variables
# Copy to .env and fill in every value before running docker compose up.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── URLs ─────────────────────────────────────────────────────────────────────
# For local Docker: keep these as-is.
# For production: set to your actual domain, e.g. https://yourcompany.com
FRONTEND_URL=http://localhost
BACKEND_URL=http://localhost:8080

# ── Database (Neon or any PostgreSQL) ────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_HEX_STRING

# ── Biometric encryption ──────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Keep this separate from SECRET_KEY — losing it makes face data unreadable.
BIOMETRIC_ENCRYPTION_KEY=REPLACE_WITH_A_STRONG_RANDOM_HEX_STRING

# ── Redis ─────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
REDIS_PASSWORD=REPLACE_WITH_A_STRONG_RANDOM_PASSWORD

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Email (Gmail App Password) ────────────────────────────────────────────────
GMAIL_USER=your-address@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Firebase ──────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── pgAdmin (dev profile only) ────────────────────────────────────────────────
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=REPLACE_WITH_A_STRONG_RANDOM_PASSWORD
