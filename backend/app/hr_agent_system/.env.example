# ── OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ── Database (Neon PostgreSQL) ───────────────────────────────
# Copy the connection string from Neon dashboard → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# ── ChromaDB (Docker HTTP server) ────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8100
# To use local file storage instead (no Docker), set CHROMA_HOST=

# ── Redis (Docker) ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── API ─────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this
API_HOST=0.0.0.0
API_PORT=8001
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Email (SMTP) ────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@yourcompany.com

# ── Face Recognition ────────────────────────────────────────
FACE_UPLOADS_DIR=./uploads/faces
FACE_CONFIDENCE_THRESHOLD=0.70
FACE_MODEL=Facenet512
