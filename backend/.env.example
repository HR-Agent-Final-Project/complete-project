# ─────────────────────────────────────────────────────────────────────────────
# AI-HR Manager — Environment Variables
# Copy this file to .env and fill in every value before starting the server.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
DEBUG=False

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
BACKEND_URL=http://localhost:8080

# ── Database ─────────────────────────────────────────────────────────────────
# Generate password with: python -c "import secrets; print(secrets.token_hex(32))"
POSTGRES_USER=hruser
POSTGRES_PASSWORD=REPLACE_WITH_A_STRONG_RANDOM_PASSWORD
POSTGRES_DB=hr_manager
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://hruser:REPLACE_WITH_A_STRONG_RANDOM_PASSWORD@localhost:5432/hr_manager

# ── JWT Auth ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_HEX_STRING

# ── Firebase (Google OAuth) ───────────────────────────────────────────────────
# Download service account key from Firebase Console → Project Settings → Service Accounts
# Save the JSON file as firebase-credentials.json (already in .gitignore)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8001/api/auth/google/callback
FRONTEND_URL=http://localhost:3000

# ── Security ──────────────────────────────────────────────────────────────────
# Allowed Host headers — prevents DNS-rebinding attacks.
# In production set to your actual API domain, e.g. api.yourcompany.com
# ALLOWED_HOSTS=["api.yourcompany.com"]

# IPs of trusted reverse proxies — only these may set X-Real-IP / X-Forwarded-For.
# Default is localhost (nginx on same host). Change if your proxy is on a different IP.
# TRUSTED_PROXY_IPS=["127.0.0.1"]

# Biometric encryption key — REQUIRED.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Keep this separate from SECRET_KEY. Losing it makes all face embeddings unreadable.
BIOMETRIC_ENCRYPTION_KEY=REPLACE_WITH_A_STRONG_RANDOM_HEX_STRING

# ── CORS Origins (comma-separated if using env list override) ────────────────
# Default: ["http://localhost:3000", "http://localhost:5173"]
# Override in code if needed; the defaults are fine for local development.

# ── OpenAI ───────────────────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Use a Gmail App Password (not your account password).
# Enable at: Google Account → Security → 2-Step Verification → App passwords
GMAIL_USER=your-address@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── File Storage ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ── Redis ────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
REDIS_PASSWORD=REPLACE_WITH_A_STRONG_RANDOM_PASSWORD
REDIS_URL=redis://:REPLACE_WITH_A_STRONG_RANDOM_PASSWORD@localhost:6379

# ── pgAdmin (Docker dev profile only — never runs in production) ──────────────
# Start with: docker compose --profile dev up pgadmin
PGADMIN_EMAIL=admin@company.com
PGADMIN_PASSWORD=REPLACE_WITH_A_STRONG_RANDOM_PASSWORD
