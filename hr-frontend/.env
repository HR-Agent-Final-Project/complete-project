# ─── HRAgent Frontend Environment ─────────────────────────────────────────────
# All variables MUST start with REACT_APP_ to be available in the browser.

# Backend API base URL (no trailing slash)
REACT_APP_API_URL=http://127.0.0.1:8080/api

# Set to "true" to use local mock data (no backend needed)
# Set to "false" to use the real backend API
REACT_APP_USE_MOCK=false

# Frontend URL (used in links inside emails sent by the backend)
REACT_APP_FRONTEND_URL=http://localhost:3000
